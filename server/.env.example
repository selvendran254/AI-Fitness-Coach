# Server
NODE_ENV=development
PORT=3001
API_VERSION=v1
CORS_ORIGIN=http://localhost:5173

# Database
# Use docker-compose (recommended): postgresql://postgres:fitcoach_dev@localhost:5433/ai_fitness_coach
DATABASE_URL="postgresql://postgres:fitcoach_dev@localhost:5433/ai_fitness_coach?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX_REQUESTS=20

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Wearables OAuth (optional — without these, demo connect works)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Mixpanel (optional)
MIXPANEL_TOKEN=

# Logging
LOG_LEVEL=info

# Email (optional — logs to console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fitcoach.app

# Web Push (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@fitcoach.demo
